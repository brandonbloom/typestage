    "@codemirror/view": "^6.43.1",
    "lines-and-columns": "^2.0.4",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@types/bun": "^1.2.22",
    "@typescript/native-preview": "latest"
